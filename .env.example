# Copie para .env e preencha. Não commite .env.

# --- Produção (Railway) ---
# DATABASE_URL=          # referência ao Postgres do projeto
# JWT_SECRET=            # string longa aleatória (mín. 16 caracteres)
# NODE_ENV=production    # cookies Secure + CSP
# ALLOW_DEMO_SEED=0      # em produção: não criar admin/membro demo no seed (só base vazia)
# SITE_PUBLIC_URL=https://betim-cor-brazil-production.up.railway.app

# --- Desenvolvimento local ---
# ALLOW_DEMO_SEED=1      # cria admin/editor/membro demo (omissão em dev)

# --- SMTP (notificações dos formulários: contato, doação, área de membros) ---
# SMTP_HOST=smtp.seuprovedor.com
# SMTP_PORT=587
# SMTP_SECURE=0
# SMTP_USER=utilizador_ou_email_completo
# SMTP_PASS=senha_ou_app_password
# SMTP_FROM=Betim Cor Brazil <no-reply@seudominio.org>
# Vários destinatários separados por vírgula (se vazio, usa o e-mail institucional do painel):
# SMTP_NOTIFY_TO=diretoria@seudominio.org,secretario@seudominio.org
# Resposta automática ao visitante após contato (opcional):
# SMTP_AUTO_REPLY_CONTATO=1
# Confirmação ao doador após pedido de doação (inclui chave PIX se configurada no painel):
# SMTP_AUTO_REPLY_DOACAO=1
# Comprovante por e-mail após inscrição pública em evento:
# SMTP_AUTO_REPLY_INSCRICAO=1
# Só se o servidor tiver certificado TLS inválido (não usar em produção sem necessidade):
# SMTP_TLS_INSECURE=1

# --- Cloudflare Turnstile (CAPTCHA opcional nos formulários públicos) ---
# TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=

# --- Object storage opcional (S3 / Cloudflare R2) — uploads sobrevivem redeploy no Railway ---
# S3_BUCKET=
# S3_REGION=auto
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_ENDPOINT=https://<account>.r2.cloudflarestorage.com
# S3_PUBLIC_URL_BASE=https://cdn.seudominio.org/uploads
# S3_KEY_PREFIX=uploads
# S3_FORCE_PATH_STYLE=1
