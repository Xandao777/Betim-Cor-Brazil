# Copie para .env e preencha. Não commite .env.

# --- SMTP (notificações dos formulários: contato, doação, área de membros) ---
# SMTP_HOST=smtp.seuprovedor.com
# SMTP_PORT=587
# SMTP_SECURE=0
# SMTP_USER=utilizador_ou_email_completo
# SMTP_PASS=senha_ou_app_password
# SMTP_FROM=Betim Cor Brazil <no-reply@seudominio.org>
# Vários destinatários separados por vírgula (se vazio, usa o e-mail institucional do painel):
# SMTP_NOTIFY_TO=diretoria@seudominio.org,secretario@seudominio.org
# Resposta automática ao visitante após contato (opcional):
# SMTP_AUTO_REPLY_CONTATO=1
# Só se o servidor tiver certificado TLS inválido (não usar em produção sem necessidade):
# SMTP_TLS_INSECURE=1
